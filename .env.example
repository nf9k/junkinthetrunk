# Junk in the Trunk — environment config
# Copy to .env and fill in values

# Database password (required)
DB_PASSWORD=changeme

# Timezone
TZ=America/Indiana/Indianapolis

# MQTT topic prefix — must match trunk-recorder plugin config
MQTT_TOPIC_PREFIX=jitr

# Frontend API URL the browser hits. Leave BLANK for the normal
# setup — nginx inside the frontend container proxies /api and
# /socket.io to the api service, so same-origin relative URLs just work.
# Only set this if your browser will load the UI from a host that
# can't reach the api via the same origin.
VITE_API_URL=
