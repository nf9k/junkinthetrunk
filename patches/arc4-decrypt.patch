+
+        if (element.contains("keys") && element["keys"].is_array()) {
+          for (const auto &k : element["keys"]) {
+            if (!k.contains("keyid") || !k.contains("algid") || !k.contains("key"))
+              continue;
+            uint16_t keyid = k["keyid"].get<uint16_t>();
+            uint8_t  algid = k["algid"].get<uint8_t>();
+            std::string hex = k["key"].get<std::string>();
+            std::vector<uint8_t> key_bytes;
+            for (size_t i = 0; i + 1 < hex.size(); i += 2) {
+              key_bytes.push_back(static_cast<uint8_t>(std::stoul(hex.substr(i, 2), nullptr, 16)));
+            }
+            System_impl *sys_impl = dynamic_cast<System_impl *>(system);
+            if (sys_impl) {
+              sys_impl->add_crypt_key(keyid, algid, key_bytes);
+              BOOST_LOG_TRIVIAL(info) << "[" << system->get_short_name() << "] Registered decrypt key: keyid=0x"
+                                      << std::hex << keyid << " algid=0x" << (int)algid << std::dec;
